DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
RUN_MIGRATIONS=1
TIME_ZONE=America/New_York
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://host:6379/0
KORONA_ACCOUNT_ID=
KORONA_BASE_URL=https://128.koronacloud.com/web/api/v3/
KORONA_USER=
KORONA_PASSWORD=
KORONA_CONNECT_TIMEOUT_SECONDS=5
KORONA_READ_TIMEOUT_SECONDS=45
KORONA_HTTP_RETRIES=3
KORONA_HTTP_BACKOFF_SECONDS=0.5
KORONA_STOCK_PAGE_SIZE=1000
KORONA_STOCK_INCREMENTAL_INTERVAL_SECONDS=120
KORONA_STOCK_RECONCILE_INTERVAL_SECONDS=86400
KORONA_STOCK_RECONCILE_HOUR=3
KORONA_STOCK_RECONCILE_MINUTE=15
KORONA_MONTHLY_RECONCILE_HOUR=4
KORONA_MONTHLY_RECONCILE_MINUTE=15
